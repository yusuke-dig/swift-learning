{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat /Users/yusukeyokota/workspace/swift-learning/MEMORY.md 2>/dev/null"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(mkdir -p *)",
      "Bash(chmod +x *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(bash lessons/*)",
      "Bash(ls *)",
      "Bash(ls -la *)",
      "Bash(cd *)",
      "Bash(cat *)",
      "Bash(pwd)",
      "Bash(echo *)",
      "Bash(swift build *)",
      "Bash(swift test *)"
    ],
    "deny": [
      "Bash(rm -rf *)"
    ],
    "additionalDirectories": [
      "../dev-learning-logs"
    ]
  }
}
